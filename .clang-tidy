HeaderFilterRegex: '.*/source/(?!.*isaacsim\.robot\.schema).*'

Checks: >
    -*,
    readability-identifier-naming,
    modernize-use-pragma-once,
    modernize-use-equals-default,
    modernize-use-enum-default,
    modernize-use-override,
    readability-braces-around-statements,
    readability-container-size-empty,
    cert-err60-cpp,
    misc-include-cleaner,
    modernize-use-nullptr,
    readability-redundant-member-init,
    modernize-use-bool-literals,
    modernize-use-using,
    readability-redundant-access-specifiers,
    misc-unused-using-decls

CheckOptions:
  # Classes, structs, and enum classes use PascalCase
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase

  # Files use PascalCase
  - key: readability-identifier-naming.FileCase
    value: CamelCase

  # Namespaces use lowercase
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case

  # Free functions use camelBack
  - key: readability-identifier-naming.FunctionCase
    value: camelBack

  # Public methods use camelBack
  - key: readability-identifier-naming.MethodCase
    value: camelBack
  # Private/protected methods use _camelBack
  - key: readability-identifier-naming.PrivateMethodCase
    value: camelBack
  - key: readability-identifier-naming.PrivateMethodPrefix
    value: _
  - key: readability-identifier-naming.ProtectedMethodCase
    value: camelBack
  - key: readability-identifier-naming.ProtectedMethodPrefix
    value: _

  # Variables use camelBack
  - key: readability-identifier-naming.VariableCase
    value: camelBack
  - key: readability-identifier-naming.ParameterCase
    value: camelBack
  # Local const variables stay camelBack (kCamelCase is for named/constexpr constants only)
  - key: readability-identifier-naming.LocalConstantCase
    value: camelBack
  - key: readability-identifier-naming.ConstantParameterCase
    value: camelBack

  # Public class members use camelBack
  - key: readability-identifier-naming.PublicMemberCase
    value: camelBack
  # Private/protected members use m_camelBack
  - key: readability-identifier-naming.PrivateMemberCase
    value: camelBack
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: m_
  - key: readability-identifier-naming.ProtectedMemberCase
    value: camelBack
  - key: readability-identifier-naming.ProtectedMemberPrefix
    value: m_

  # Static variables use s_camelBack
  - key: readability-identifier-naming.StaticVariableCase
    value: camelBack
  - key: readability-identifier-naming.StaticVariablePrefix
    value: s_

  # Constants — scoped rules handle static/global/class constexpr correctly;
  # a standalone ConstexprVariable rule would conflict with StaticConstant (s_k prefix).
  - key: readability-identifier-naming.GlobalConstantCase
    value: CamelCase
  - key: readability-identifier-naming.GlobalConstantPrefix
    value: g_k
  - key: readability-identifier-naming.ClassConstantCase
    value: CamelCase
  - key: readability-identifier-naming.ClassConstantPrefix
    value: s_k
  - key: readability-identifier-naming.StaticConstantCase
    value: CamelCase
  - key: readability-identifier-naming.StaticConstantPrefix
    value: s_k
  - key: readability-identifier-naming.GlobalVariableCase
    value: camelBack
  - key: readability-identifier-naming.GlobalVariablePrefix
    value: g_

  # Enum values use eCamelCase
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key: readability-identifier-naming.EnumConstantPrefix
    value: e

  # Macros use UPPER_CASE (ignore reserved identifiers starting with __)
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key: readability-identifier-naming.MacroDefinitionIgnoredRegexp
    value: "^__.*"
