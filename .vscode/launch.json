{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "EXP_PATH": "${workspaceFolder}/source/python_samples/experiences"
            },
            "envFile": "${workspaceFolder}/.vscode/.python_samples.env",
            "preLaunchTask": "setup_python_env"
        },
        {
            "name": "(Linux) isaac-sim [release]",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/_build/kit_release/_build/linux-x86_64/release/kit",
            "args": ["${workspaceFolder}/_build/linux-x86_64/release/apps/isaac-sim.kit",
                "--ext-folder", "${workspaceFolder}/_build/linux-x86_64/release/exts",
                "--ext-folder", "${workspaceFolder}/_build/linux-x86_64/release/apps"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "envFile": "${workspaceFolder}/.vscode/.pxr_plugin.env",
        },
        {
            "name": "(Linux) isaac-sim [debug]",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/_build/kit_debug/_build/linux-x86_64/debug/kit",
            "args": ["${workspaceFolder}/_build/linux-x86_64/debug/apps/isaac-sim.kit",
                "--ext-folder", "${workspaceFolder}/_build/linux-x86_64/debug/exts",
                "--ext-folder", "${workspaceFolder}/_build/linux-x86_64/debug/apps"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "envFile": "${workspaceFolder}/.vscode/.pxr_plugin.env",
        },
    ]
}
