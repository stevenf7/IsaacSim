{
    "app": {
        "window": {
            "width": 1440,
            "height": 900,
            "title": "Omniverse Isaac Sim"
        },
        "settings": {
            "persistent": true
        },
        "extensions": {
            "folders2": ["${kit}/exts", "${kit}/extsPhysics", "${app}/../exts"],
            "foldersBuiltin": [
                "${kit}/extensions/extensions-bundled",
                "${kit}/extensions/extensions-other",
                "${documents}/extensions",
                "${app}/../extensions"
            ],
            "enabledBuiltin": [
                "omni.renderer-rtx",
                "omni.stats",
                "omni.kit.default",
                "omni.kit.editor-full",
                "omni.kit.builtin.init",
                "omni.kit.builtin.menu",
                "omni.kit.builtin.file_menu",
                "omni.kit.builtin.extensions_manager_window",
                "omni.kit.builtin.preferences_window",
                "omni.kit.builtin.provide_feedback_window",
                "omni.kit.builtin.profiler",
                "omni.kit.builtin.audio_settings_window",
                "omni.kit.builtin.audio_player_window",
                "omni.kit.builtin.render_settings_window",
                "omni.kit.builtin.test_runner",
                "omni.kit.builtin.material_library",
                "omni.kit.widget.live",
                "omni.kit.widget.stage",
                "omni.kit.widget.layers",
                "omni.kit.window.content",
                "omni.kit.window.stats",
                "omni.kit.window.tagging",
                "omni.kit.window.viewport",
                "omni.kit.window.script_editor",
                "omni.kit.window.console",
                "omni.kit.window.details",
                "omni.kit.window.toolbar",
                "omni.kit.window.usd_paths",
                "omni.kit.primitive.mesh",
                "omni.utils.utilities_menu",
                "omni.utils.movie_capture",
                "omni.utils.collect_tool",
                "omni.assetimport",
                "omni.kit.context_menu",
                "omni.physx",
                "omni.physx.ui",
                "omni.kit.selection",
                "omni.kit.stage_templates",
                "omni.isaac.about",
                "omni.isaac.urdf",
                "omni.isaac.utils",
                "omni.isaac.lidar",
                "omni.isaac.manip",
                "omni.isaac.dynamic_control",
                "omni.isaac.motion_planning",
                "omni.isaac.samples",
                "omni.isaac.robot_engine_bridge",
                "omni.isaac.dr"
            ]
        },
        "renderer": {
            "skipWhileMinimized": false,
            "sleepMsOnFocus": 0,
            "sleepMsOutOfFocus": 0,
            "resolution": {
                "width": 1280,
                "height": 720,
                "list": [2048, 1080, 1920, 1208, 1920, 1080, 960, 604, 1280, 720, 1024, 1024, 512, 512]
            }
        }
    },
    "rtx": {
        "raytracing": {
            "fractionalCutoutOpacity": false
        },
        "hydra": {
            "enableSemanticSchema": true
        }
    },
    "persistent": {
        "app": { "stage": { "upAxis": "Z" } },
        "physics": {
            "maxNumSteps": 3.0,
            "updateToUsd": false
        }
    },
    "ngx":{
        "enabled": false
    }
}
