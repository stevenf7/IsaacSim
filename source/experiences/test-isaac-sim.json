{
    "app": {
        "window": {
            "title": "Omniverse Isaac Sim Tests"
        },
        "extensions": {
            "folders2": [
                "${kit}/exts",
                "${kit}/extsPhysics",
                "${app}/../exts"
            ],
            "foldersBuiltin": [
                "${kit}/extensions/extensions-bundled",
                "${kit}/extensions/extensions-other",
                "${documents}/extensions",
                "${app}/../extensions"
            ],
            "enabledBuiltin": [
                "omni.renderer-rtx",
                "omni.kit.editor-full",
                "omni.kit.builtin.file_menu",
                "omni.kit.builtin.toolbar",
                "omni.kit.window.viewport",
                "omni.utils.utilities_menu",
                "omni.utils.usd_paths",
                "omni.kit.context_menu",
                "omni.physx",
                "omni.isaac.dynamic_control",
                "omni.isaac.dr",
                "omni.isaac.lidar",
                "omni.isaac.motion_planning",
                "omni.isaac.utils",
                "omni.isaac.urdf",
                "omni.isaac.samples",
                "omni.isaac.tests"
            ]
        },
        "renderer": {
            "skipWhileMinimized": false,
            "sleepMsOnFocus": 0,
            "sleepMsOutOfFocus": 0
        }
    },
    "exts": {
        "omni.kit.test": {
            "printTests": true,
            "includeTests": [
                "omni.isaac.tests.*"
            ],
            "excludeTests": [
                "omni.isaac.tests.domain_randomizer.*",
                "omni.isaac.tests.samples.*"
            ],
            "runTestsAndQuit": true
        }
    },
    "persistent": {
        "app": {
            "viewport": {
                "displayOptions": 3085
            }
        }
    }
}