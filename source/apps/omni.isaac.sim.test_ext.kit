[package]
keywords = ["app"]
title = "Isaac Extension Test Run Environment"
version = "1.0.0"

[settings]
app.asyncRendering = false                                          ### async rendering settings
app.asyncRenderingLowLatency = false                                ### async rendering settings
app.fastShutdown = 1
app.file.ignoreUnsavedOnExit = true
app.hydraEngine.waitIdle = false
app.name = "Isaac-Sim"
app.renderer.skipWhileMinimized = false
app.renderer.sleepMsOnFocus = 0
app.renderer.sleepMsOutOfFocus = 0
app.settings.fabricDefaultStageFrameHistoryCount = 3                # needed for omni.syntheticdata TODO105 Still true?
app.settings.persistent = false
app.viewport.createCameraModelRep = false                           # needed for replicator
app.vulkan = true                                                   # Explicitly enable Vulkan (on by default on Linux, off by default on Windows)
crashreporter.data.experience = "Isaac Sim"
crashreporter.skipOldDumpUpload = true
exts."isaacsim.ros2.bridge".publish_without_verification = true
exts."omni.kit.pipapi".installCheckIgnoreVersion = true
exts."omni.kit.renderer.core".present.enabled = false
exts."omni.kit.renderer.core".present.presentAfterRendering = false
exts."omni.kit.test".testExtDefaultTimeout = 600                    # Default extension test timeout (can be overriden by extensions), in seconds:
exts."omni.kit.thumbnails.usd".thumbnail_on_save = false
exts."omni.kit.viewport.window".startup.windowName = "Viewport"     # Rename from viewport next
omni.kit.plugin.syncUsdLoads = true
omni.replicator.asyncRendering = false                              ### async rendering settings
persistent.app.stage.upAxis = "Z"
persistent.app.viewport.defaults.tickRate = 120
persistent.app.viewport.displayOptions = 31951
persistent.omni.replicator.captureOnPlay = true
persistent.omnigraph.disablePrimNodes = true
persistent.omnigraph.updateToUsd = false
persistent.omnigraph.useSchemaPrims = true
persistent.physics.visualizationDisplayJoints = false
persistent.renderer.startupMessageDisplayed = true
persistent.simulation.defaultMetersPerUnit = 1.0
persistent.simulation.minFrameRate = 15
renderer.multiGpu.autoEnable = true
renderer.multiGpu.enabled = true
rtx-transient.dlssg.enabled = false
'rtx-transient'.resourcemanager.enableTextureStreaming = true
rtx.descriptorSets = 360000
rtx.hydra.enableSemanticSchema = true
rtx.hydra.materialSyncLoads = true
rtx.materialDb.syncLoads = true
rtx.newDenoiser.enabled = true
rtx.reservedDescriptors = 900000
app.gatherRenderResults = true # True to prevent artifacts in multiple viewport configurations, can be set to false for better performance in some cases
rendergraph.mgpu.backend = "copyQueue" # In MGPU configurations, This setting can be removed if IOMMU is disabled for better performance

# TODO: Remove these settings
exts."omni.kit.registry.nucleus".registries = [
] # This forces extensions to be local when testing
[settings.app.exts] # Register extension folder from this repo in kit
folders = [
    "${app}/../exts",
    "${app}/../extscache",
    "${app}/../extsPhysics",
    "${app}/../extsUser",
    "${app}/../extsDeprecated",
]

# FOR DEVELOPMENT - START #
[settings]
# persistent.isaac.asset_root.default = "omniverse://isaac-dev.ov.nvidia.com"
persistent.isaac.asset_root.default = "https://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5"

exts."isaacsim.asset.browser".folders = [
    "http://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5/Isaac/Robots",
    "http://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5/Isaac/People",
    "http://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5/Isaac/Props",
    "http://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5/Isaac/Environments",
    "http://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5/Isaac/Materials",
    "http://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5/Isaac/Samples",
    "http://omniverse-content-staging.s3-us-west-2.amazonaws.com/Assets/Isaac/4.5/Isaac/Sensors",
]
# FOR DEVELOPMENT - END #
