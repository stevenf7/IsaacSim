<?xml version="1.0"?>
<!-- Test URDF for mimic joint parsing.
     This file tests that mimic joints are correctly configured regardless of parse order.
     - "a_mimic_joint" is lexicographically BEFORE "source_joint" (tests deferred configuration)
     - "z_mimic_joint" is lexicographically AFTER "source_joint" (standard case)
-->
<robot name="test_mimic">
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="link_source">
    <visual>
      <geometry>
        <box size="0.08 0.08 0.2"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.08 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="link_a">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <link name="link_z">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- Source joint that other joints will mimic -->
  <joint name="source_joint" type="revolute">
    <parent link="base_link"/>
    <child link="link_source"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <!-- Mimic joint with name lexicographically BEFORE source_joint -->
  <!-- This tests that mimic configuration works even when parsed before source -->
  <joint name="a_mimic_joint" type="revolute">
    <parent link="link_source"/>
    <child link="link_a"/>
    <origin xyz="0.1 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="50" velocity="1.0"/>
    <mimic joint="source_joint" multiplier="1.5" offset="0.1"/>
  </joint>

  <!-- Mimic joint with name lexicographically AFTER source_joint -->
  <!-- Standard case where source exists when mimic is parsed -->
  <joint name="z_mimic_joint" type="revolute">
    <parent link="link_source"/>
    <child link="link_z"/>
    <origin xyz="-0.1 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="50" velocity="1.0"/>
    <mimic joint="source_joint" multiplier="-1.0" offset="0.0"/>
  </joint>
</robot>

