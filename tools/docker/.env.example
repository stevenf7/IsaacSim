# ============================================================================
# Docker Compose environment variables for Isaac Sim + Web Viewer
# Copy this file to .env and uncomment/edit the values you need.
# ============================================================================

# --- Isaac Sim Image ---
# Use a prebuilt NGC image instead of the locally built isaac-sim-docker:latest.
# This skips the local build steps (prep_docker_build.sh and build_docker.sh).
# ISAAC_SIM_IMAGE=nvcr.io/nvidia/isaac-sim:6.0.0-dev2

# --- Persistent Data ---
# Host path for cache, config, logs, and data (must be owned by uid 1234).
# Use a full absolute path; ~ is not expanded by Docker Compose.
# ISAAC_SIM_DATA=/home/myuser/docker/isaac-sim

# --- WebRTC Streaming ---
# Host IP for Isaac Sim WebRTC streaming. Set this to your machine's LAN/public
# IP when connecting from another device. The web viewer bakes this at build
# time, so use --build when changing it.
# ISAACSIM_HOST=127.0.0.1

# Signal port for WebRTC signaling (TCP).
# ISAACSIM_SIGNAL_PORT=49100

# Media port for WebRTC stream (UDP).
# ISAACSIM_STREAM_PORT=47998

# --- Web Viewer ---
# Port the web viewer listens on (override for multi-instance deployments).
# WEB_VIEWER_PORT=8210

# --- GPU ---
# GPU index to pin Isaac Sim to. Default is "all" (use all available GPUs).
# Set to a specific index (e.g. 0 or 1) for multi-instance with dedicated GPUs.
# GPU_DEVICE=all
