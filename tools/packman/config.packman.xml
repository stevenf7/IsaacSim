<config remotes="cloudfront urm gtl gtl_rendering">
    <remote2 name="cloudfront">
        <transport actions="download" protocol="http" packageLocation="d4i3qtqj3r0z5.cloudfront.net/${name}@${version}" />
        <transport actions="list upload" configUrl="https://gitlab-master.nvidia.com/hfannar/packman-transports/raw/main/d4i3qtqj3r0z5.cloudfront.toml" />
    </remote2>
    <remote2 name="gtl">
        <transport actions="download list upload"
            configUrl="https://gitlab-master.nvidia.com/hfannar/packman-transports/raw/main/gtl.toml" />
    </remote2>
    <remote2 name="urm">
        <transport actions="download" protocol="https" packageLocation="urm.nvidia.com/artifactory/ct-omniverse-generic/pkgs/${name}/${name}@${version}" />
    </remote2>
    <remote name="gitlab-repo" type="https" packageLocation="gitlab-master.nvidia.com/api/v4/projects/omniverse%2Frepo%2F${name}/repository/archive.zip?sha=${version}" />
    <remote2 name="gtl_rendering">
        <transport actions="download list upload"
            configUrl="https://gitlab-master.nvidia.com/hfannar/packman-transports/raw/main/gtl.toml" />
    </remote2>
</config>
